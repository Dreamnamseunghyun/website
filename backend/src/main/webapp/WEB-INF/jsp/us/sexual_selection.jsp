<script src="https://code.jquery.com/jquery-latest.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@9"></script>
<script>


    $("header").load("header.html");
    $("footer").load("footer.html");


    $(".userSelection .selectionBox").click(function () {
        var selection_box_check = $(this).hasClass("select");

        if (selection_box_check) {//? нғқ???ҳмһҲ?јл©ҙ
            $(this).removeClass("select").siblings("div").removeClass("select");
        } else {
            $(this).addClass("select").siblings("div").removeClass("select");
        }
    })


    $(".sexual_btn").click(function () {
        let sex = $(".userSelection .selectionBox.select").attr("data-sexual");

        if ($(".userSelection .selectionBox.select").length <= "0") {//?ұлі„
            Swal.fire('?ұлі„??? нғқ??мЈјм„ё??, '', 'warning');
            return;
        }

        //?өкіј
        $.ajax({
            url: '<c:url value="/us/reserve"/>',
            method: 'POST',
            contentType: 'application/json',
            dataType: 'json',
            data: JSON.stringify({
                userId: <c:out value="${userId}"/>,
                sex: sex,
            }),
        }).then(function (response) {
            if (response.code === 'SUCCESS') {
                <c:choose>
                <c:when test="${reserveType == 'hospital'}">
                location.href = 'reserve_checkup.html?reserveType=hospital&userId=<c:out value="${userId}"/>';
                </c:when>
                <c:when test="${reserveType == 'date'}">
                location.href = 'reserve_checkup_date.html?reserveType=date&userId=<c:out value="${userId}"/>';
                </c:when>
                <c:when test="${reserveType == 'item'}">
                if (sex === 'M') {
                    location.href = 'checkup_selection_male.html?userId=<c:out value="${userId}"/>';
                } else {
                    location.href = 'checkup_selection_female.html?userId=<c:out value="${userId}"/>';
                }
                </c:when>
                </c:choose>
            } else {
                Swal.fire(response.message, '', 'error');
            }
        }, function (jqXHR) {
            console.log(jqXHR);
            Swal.fire('Error!', '', 'error');
        });
    });
</script>
