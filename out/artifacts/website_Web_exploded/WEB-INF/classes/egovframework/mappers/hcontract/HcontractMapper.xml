<mapper namespace="kr.co.sitebuilder.hospital.service.mapper.HcontractMapper">
    <resultMap id="mapHcontracts" type="HcontractVO" autoMapping="true">
        <id property="companyId" column="company_id"/>
        <id property="centerId" column="center_id"/>
        <id property="checkupYear" column="checkup_year"/>

        <collection property="contractManager" ofType="CenterManagerVO">
            <result column="contract_manager_name" property="centerManagerName"/>
            <result column="contract_manager_email" property="email"/>
            <result column="contract_manager_telephone" property="telephone"/>
            <result column="contract_manager_mobile" property="mobile"/>
        </collection>
        <collection property="reserveManager" ofType="CenterManagerVO">
            <result column="reserve_manager_name" property="centerManagerName"/>
            <result column="reserve_manager_email" property="email"/>
            <result column="reserve_manager_telephone" property="telephone"/>
            <result column="reserve_manager_mobile" property="mobile"/>
        </collection>
        <collection property="resultManager" ofType="CenterManagerVO">
            <result column="result_manager_name" property="centerManagerName"/>
            <result column="result_manager_email" property="email"/>
            <result column="result_manager_telephone" property="telephone"/>
            <result column="result_manager_mobile" property="mobile"/>
        </collection>
    </resultMap>

    <resultMap id="mapHcontract" type="HcontractVO" autoMapping="true">
        <id property="hospitalId" column="hospital_id"/>
        <collection property="hcontracts" ofType="HcontractVO" resultMap="mapHcontracts">
            <result column="center_id" property="centerId"/>
            <result property="contractManagerNameCrypt" column="contract_manager_name"/>
            <result property="reserveManagerNameCrypt" column="reserve_manager_name"/>
            <result property="resultManagerNameCrypt" column="result_manager_name"/>
        </collection>
    </resultMap>
    <select id="selectHcontractList" resultMap="mapHcontract">
        SELECT H.hospital_name
             , H.hospital_id
             , HC.center_name
             , HC.center_id
             , C.company_name
             , C.company_id
             , CASE CMC.contract WHEN 1 THEN HM.center_manager_name END AS contract_manager_name
             , CASE CMC.reserve WHEN 1 THEN HM.center_manager_name END  AS reserve_manager_name
             , CASE CMC.result WHEN 1 THEN HM.center_manager_name END   AS result_manager_name
        FROM hospital H
                     LEFT JOIN center HC
                ON H.hospital_id = HC.hospital_id
                     LEFT JOIN center_manager HM
                ON HC.center_id = HM.center_id
                     LEFT JOIN center_manager_company CMC
                ON HM.user_id = CMC.user_id
                     LEFT JOIN company C
                ON C.company_id = CMC.company_id
        WHERE H.deleted_at is NULL
          AND HC.deleted_at is NULL
          AND HM.deleted_at is NULL
          AND CMC.deleted_at is NULL
          AND C.deleted_at is NULL
    </select>

