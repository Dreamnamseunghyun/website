    <resultMap id="mapHcontractIndex" type="HcontractVO" autoMapping="true">
        <id property="companyId" column="company_id"/>
        <id property="centerId" column="center_id"/>
        <id property="checkupYear" column="checkup_year"/>
        <result property="contractManagerNameCrypt" column="contract_manager_name"/>
        <result property="reserveManagerNameCrypt" column="reserve_manager_name"/>
        <result property="resultManagerNameCrypt" column="result_manager_name"/>
    </resultMap>
    <select id="selectHcontract" resultMap="mapHcontractIndex">
        SELECT DISTINCT CONT.checkup_contract_id
                      , hospital_center_view.hospital_name
                      , hospital_center_view.hospital_id
                      , hospital_center_view.center_id
                      , hospital_center_view.center_name
                      , C.company_name
                      , C.company_id
                      , CH.checkup_year
                      , CMC.user_id
                      , HM.user_id
                      , CASE CMC.contract WHEN 1 THEN HM.center_manager_name END AS contract_manager_name
                      , CASE CMC.contract WHEN 1 THEN HM.email END               AS contract_manager_email
                      , CASE CMC.contract WHEN 1 THEN HM.telephone END           AS contract_manager_telephone
                      , CASE CMC.contract WHEN 1 THEN HM.mobile END              AS contract_manager_mobile
                      , CASE CMC.reserve WHEN 1 THEN HM.center_manager_name END  AS reserve_manager_name
                      , CASE CMC.reserve WHEN 1 THEN HM.email END                AS reserve_manager_email
                      , CASE CMC.reserve WHEN 1 THEN HM.telephone END            AS reserve_manager_telephone
                      , CASE CMC.reserve WHEN 1 THEN HM.mobile END               AS reserve_manager_mobile
                      , CASE CMC.result WHEN 1 THEN HM.center_manager_name END   AS result_manager_name
                      , CASE CMC.result WHEN 1 THEN HM.email END                 AS result_manager_email
                      , CASE CMC.result WHEN 1 THEN HM.telephone END             AS result_manager_telephone
                      , CASE CMC.result WHEN 1 THEN HM.mobile END                AS result_manager_mobile
        FROM company_checkup CH
                     JOIN company C ON CH.company_id = C.company_id AND C.deleted_at IS NULL
                     LEFT JOIN checkup_contract CONT ON CH.company_checkup_id = CONT.company_checkup_id
                AND CH.company_checkup_id = CONT.company_checkup_id
                     JOIN hospital_center_view ON CONT.hospital_id = hospital_center_view.hospital_id
                     JOIN center_manager_company CMC
                ON CMC.company_id = C.company_id AND CMC.deleted_at is NULL
                     JOIN center_manager HM
                ON HM.user_id = CMC.user_id AND hospital_center_view.center_id = HM.center_id
        WHERE HM.deleted_at is NULL
          AND C.deleted_at is NULL
          AND C.company_id is NOT NULL
          AND hospital_center_view.hospital_id = #{hospitalId}
        <if test="checkupYear != null">
            AND CH.checkup_year = #{checkupYear}
        </if>
        ORDER BY C.company_name, hospital_center_view.center_name
    </select>
</mapper>
