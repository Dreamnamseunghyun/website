<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.0.xsd http://www.springframework.org/schema/mvc http://www.springframework.org/schema/mvc/spring-mvc.xsd">

    <bean id="commonInterceptor" class="kr.co.dsong.ggsj.common.web.CommonInterceptor"/>
    <mvc:interceptors>
        <mvc:interceptor>
            <mvc:mapping path="/**"/>

            <!-- resource -->
            <mvc:exclude-mapping path="/favicon.ico"/>
            <mvc:exclude-mapping path="/css/**"/>
            <mvc:exclude-mapping path="/img/**"/>
            <mvc:exclude-mapping path="/js/**"/>
            <mvc:exclude-mapping path="/lib/**"/>

            <mvc:exclude-mapping path="/common/**"/>

            <mvc:exclude-mapping path="/logout"/>

            <mvc:exclude-mapping path="/pm/login"/>
            <mvc:exclude-mapping path="/hm/login"/>
            <mvc:exclude-mapping path="/cm/login"/>

            <!-- user -->
            <mvc:exclude-mapping path="/us"/>
            <mvc:exclude-mapping path="/us/login"/>
            <mvc:exclude-mapping path="/us/find/id"/>
            <mvc:exclude-mapping path="/us/find/pw"/>
            <mvc:exclude-mapping path="/us/find/data"/>
            <mvc:exclude-mapping path="/us/find/data_pw"/>
            <mvc:exclude-mapping path="/pm/employee/reset"/>
            <mvc:exclude-mapping path="/us/employee/reset"/>

            <!-- TODO: 나중에 html 제거 -->
            <mvc:exclude-mapping path="/us/logo.html"/>
            <mvc:exclude-mapping path="/us/footer.html"/>
            <mvc:exclude-mapping path="/us/header.html"/>
            <mvc:exclude-mapping path="/us/index.html"/>
            <mvc:exclude-mapping path="/us/find_id.html"/>
            <mvc:exclude-mapping path="/us/find_password.html"/>
            <mvc:exclude-mapping path="/us/faq.html"/>
            <mvc:exclude-mapping path="/us/faq/**"/>
            <mvc:exclude-mapping path="/us/common_sense.html"/>
            <mvc:exclude-mapping path="/us/common_sense/**"/>
            <mvc:exclude-mapping path="/us/healthsense/**"/><!--healthsense api-->
            <mvc:exclude-mapping path="/us/notice/**"/><!--notice api-->
            <mvc:exclude-mapping path="/us/notice.html"/>
            <mvc:exclude-mapping path="/us/notice_write.html"/>


            <!-- 로그인 안하고 보는 이미지 URL -->
            <mvc:exclude-mapping path="/storage/healthsense/**"/>


            <!-- robots.txt -->
            <mvc:exclude-mapping path="/robots.txt"/>

            <!-- Bing 검색 등록 -->
            <mvc:exclude-mapping path="/BingSiteAuth.xml"/>

            <!-- Naver 검색 등록 -->
            <mvc:exclude-mapping path="/naverc1fba8449506ee1e27769484ab58edfe.html"/>

            <!-- TODO: 추후 정리되면 삭제! -->
            <mvc:exclude-mapping path="/publish/**"/>

            <ref bean="commonInterceptor"/>
        </mvc:interceptor>
    </mvc:interceptors>
</beans>
