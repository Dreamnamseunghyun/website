<script>
    // $("header .logo > a").load("logo.html");


    //헤더 스크롤다운
    $(function () {

        var header_height = $("header").height() - 40;

        $(window).scroll(function () {
            var scroll = getCurrentScroll();
            if (scroll >= header_height) {
                $('header').addClass('scroll_down');
            } else {
                $('header').removeClass('scroll_down');
            }
        });


        //렌더시 스크롤 내려가있으면
        $("document").ready(function () {
            var render_scroll = $(document).scrollTop();
            if (render_scroll >= 10) {
                $('header').addClass('scroll_down');
            } else {
                $('header').removeClass('scroll_down');
            }

        })

        function getCurrentScroll() {
            return window.pageYOffset || document.documentElement.scrollTop;
        }
    });


    /*btn*/
    $(".btn .btn_inner").mouseenter(function (e) {
        var parentOffset = $(this).offset();

        var relX = e.pageX - parentOffset.left;
        var relY = e.pageY - parentOffset.top;
        $(this).prev(".button_on_circle").css({"left": relX, "top": relY});
        $(this).prev(".button_on_circle").removeClass("desplode-circle");
        $(this).prev(".button_on_circle").addClass("explode-circle");

    });

    $(".btn .btn_inner").mouseleave(function (e) {

        var parentOffset = $(this).offset();

        var relX = e.pageX - parentOffset.left;
        var relY = e.pageY - parentOffset.top;
        $(this).prev(".button_on_circle").css({"left": relX, "top": relY});
        $(this).prev(".button_on_circle").removeClass("explode-circle");
        $(this).prev(".button_on_circle").addClass("desplode-circle");

    });


    $("header .sub_menu").on("mouseover focusin", function () {
        $(this).parents("li").addClass("hover")
    })

    $("header .sub_menu").on("mouseleave blur", function () {
        $(this).parents("li").removeClass("hover")
    })

    function delay_alert(){
        Swal.fire('현재 페이지 준비 중에 있습니다.\n 빠른 시일 내에 오픈하도록\n하겠습니다 :D', '', 'error' );
    }











    /*햄버거 메뉴*/
    var McButton = $("header .McButton");
    var all_menu = $("header .all_menu");
    var McBar1 = McButton.find("b:nth-child(1)");
    var McBar2 = McButton.find("b:nth-child(2)");
    var McBar3 = McButton.find("b:nth-child(3)");
    McButton.click(function()
    {
        $(this).toggleClass("active");
        if (McButton.hasClass("active"))
        {
            McBar1.velocity(
                {
                    top: "50%"
                },
                {
                    duration: 200,
                    easing: "swing"
                });
            McBar3.velocity(
                {
                    top: "50%"
                },
                {
                    duration: 200,
                    easing: "swing"
                }).velocity(
                {
                    rotateZ: 90 + "deg"
                },
                {
                    duration: 800,
                    delay: 200,
                    easing: [500, 20]
                });
            McButton.velocity(
                {
                    rotateZ: 135 + "deg"
                },
                {
                    duration: 800,
                    delay: 200,
                    easing: [500, 20]
                });
            $(".McButton b").css(
                {
                    background: "#fff"
                })
        }
        else
        {
            McButton.velocity("reverse");
            McBar3.velocity(
                {
                    rotateZ: 0 + "deg"
                },
                {
                    duration: 800,
                    easing: [500, 20]
                }).velocity(
                {
                    top: "100%"
                },
                {
                    duration: 200,
                    easing: "swing"
                });
            McBar1.velocity("reverse",
                {
                    delay: 800
                })
        }
    });



    $(".all_menu_mo_bg").click(function()
    {
        McButton.removeClass("active");
        McButton.velocity("reverse");
        McBar3.velocity(
            {
                rotateZ: 0 + "deg"
            },
            {
                duration: 800,
                easing: [500, 20]
            }).velocity(
            {
                top: "100%"
            },
            {
                duration: 200,
                easing: "swing"
            });
        McBar1.velocity("reverse",
            {
                delay: 800
            })
    });

    function mc_button_scroll()
    {
        $("header .McButton").css(
            {
                transition: "none"
            });
        $("header .McButton b").css(
            {
                transition: "background 2.6s cubic-bezier(.19,1,.22,1) 0.2s"
            })
    }




    var all_menu_mo_list_height = $(".all_menu_mo .list_area > li:first-child .list_area_sub li").height() + 15;
    var all_menu_mo_list_length = $(".all_menu_mo .list_area > li:first-child .list_area_sub li").length;
    $(".all_menu_mo .list_area > li > a").click(function()
    {
        var b = $(this).parents("li").find(".list_area_sub").children("li").height() + 18;
        var a = $(this).parents("li").find(".list_area_sub").children("li").length;
        $(this).parents("li").toggleClass("active").siblings("li").removeClass("active").find(".list_area_sub").css(
            {
                height: "0"
            });
        if ($(this).parents("li").hasClass("active"))
        {
            $(this).parents("li").addClass("active");
            $(this).parents("li").find(".list_area_sub").css(
                {
                    height: (b * a)
                })
        }
        else
        {
            $(this).parents("li").removeClass("active");
            $(this).parents("li").find(".list_area_sub").css(
                {
                    height: "0"
                })
        }
    });


    function mob_motion()
    {


        McButton.click(function()
        {
            if (McButton.hasClass("active"))
            {
                TweenMax.to($(".all_menu_mo"), 1,
                    {
                        x: 0 + "%",
                        ease: Expo.easeInOut
                    });
                TweenMax.to($(".all_menu_mo_bg"), 1,
                    {
                        autoAlpha: 1,
                        ease: Expo.easeInOut
                    });



            }
            else
            {
                TweenMax.to($(".all_menu_mo"), 1,
                    {
                        x: 100 + "%",
                        ease: Expo.easeInOut
                    });
                TweenMax.to($(".all_menu_mo_bg"), 1,
                    {
                        autoAlpha: 0,
                        ease: Expo.easeInOut
                    });
                $("header .gnb_all").css(
                    {
                        top: "0"
                    });



            }
        });

        function a()
        {
            TweenMax.to($(".all_menu_mo"), 1,
                {
                    x: 0 + "%",
                    ease: Expo.easeInOut
                });
            TweenMax.to($(".all_menu_mo_bg"), 1,
                {
                    autoAlpha: 1,
                    ease: Expo.easeInOut
                });


        }
        if (McButton.hasClass("active"))
        {
            a()
        }


        $(".all_menu_mo_bg").click(function()
        {
            TweenMax.to($(".all_menu_mo"), 1,
                {
                    x: 100 + "%",
                    ease: Expo.easeInOut
                });
            TweenMax.to($(".all_menu_mo_bg"), 1,
                {
                    autoAlpha: 0,
                    ease: Expo.easeInOut
                });


            $(".all_menu").css(
                {
                    transform: "translate(100%)"
                });
            $(".all_menu_bg").css(
                {
                    visibility: "hidden",
                    opacity: "0",
                    transition: "all 1s cubic-bezier(.19,1,.22,1)"
                });

        });

    }//mob_motion




    function pc_motion()
    {


        function a()
        {
            TweenMax.to($(".all_menu_mo"), 1,
                {
                    x: 100 + "%",
                    ease: Expo.easeInOut
                });
            TweenMax.to($(".all_menu_mo_bg"), 1,
                {
                    autoAlpha: 0,
                    ease: Expo.easeInOut
                });


        }
        if (McButton.hasClass("active"))
        {
            a()
        }

    }



    $(document).ready(function(){
        mob_motion();
        if(window.matchMedia("(max-width:1300px)").matches){
            mob_motion();
        }
        else{
            pc_motion();
        }

        function matchFunction(){
            if(window.matchMedia("(max-width:1300px)").matches){
                mob_motion();
            }
            else{
                pc_motion();
            }
        }
        window.matchMedia("(max-width:1300px)").addListener(matchFunction);

    });





</script>


